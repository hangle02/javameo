        "language": "markdown",
        "id": "04bb8261-e944-424a-8573-e3cd44438c54"
      }
    },
    {
      "id": "7b15930b-dcfc-4bab-a6ab-38dda79da2d3",
      "cell_type": "code",
      "source": "int score = 5;\r\nint a = 1;\r\nint b = 2;\r\nIO.println(a/b == 0);\r\nIO.println( a/b == 0.5);\r\nIO.println( a * 1.0 /b == 0.5);\r\nIO.println((double) a/b == 0.5);\r\n",
      "metadata": {
        "language": "java",
        "id": "7b15930b-dcfc-4bab-a6ab-38dda79da2d3",
        "executionSummary": {
          "executionOrder": 12,
          "success": true
        }
      },
      "execution_count": 12,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "true\r\nfalse\r\ntrue\r\ntrue\r\n"
          },
          "metadata": {},
          "execution_count": 12
        }
      ]
    },
    {
