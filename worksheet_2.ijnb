      }
    },
    {
      "id": "b905905e-5af1-4244-8e9e-3a42b872698c",
      "cell_type": "code",
      "source": "int[] u = {3,1,4};\r\nint[] v = new int[u.length];\r\nfor (int i =0; i < u.length; i++){\r\n    v[i] = 2* u[i];\r\n}\r\n\r\nfor (int i = 0; i < v.length; i ++){\r\n    IO.print(v[i]);\r\n    IO.print(\", \");\r\n}\r\nIO.println(Arrays.toString(v));",
      "metadata": {
        "language": "java",
