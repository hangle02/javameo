    {
      "id": "f790189a-07d1-432b-a344-0b8ad3104af1",
      "cell_type": "code",
      "source": "void rebalance_BST(TreeNode root){\r\n    if(root==null){return;}\r\n    else{\r\n        List<Integer> datas = new ArrayList<>();\r\n        inorder_traversal(root, datas);\r\n        root = buildTree(datas, 0, datas.size()-1);\r\n    }\r\n}\r\n\r\nvoid inorder_traversal(TreeNode root, List<Integer> datas){\r\n    if(root==null){return;}\r\n    else{\r\n        inorder_traversal(root.left, datas);\r\n        datas.add(root.data);\r\n        inorder_traversal(root.right, datas);\r\n    }\r\n}\r\n\r\nTreeNode buildTree(List<Integer> datas, int left, int right){\r\n    if(left>right){return null;}\r\n    else{\r\n        int mid = left + (right-left)/2;\r\n        TreeNode root = new TreeNode(datas.get(mid),null,null);\r\n        root.left = buildTree(datas, left, mid-1);\r\n        root.right = buildTree(datas, mid+1, right);\r\n        return root;\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "id": "f790189a-07d1-432b-a344-0b8ad3104af1",
