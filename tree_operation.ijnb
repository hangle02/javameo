    {
      "id": "a2259a74-21c1-46c4-ac2b-18ce4ae68be6",
      "cell_type": "code",
      "source": "class Node{\r\n    int data;\r\n    Node next;\r\n    public Node(int data_, Node next_){\r\n        this.data = data_;\r\n        this.next = next_;\r\n    }\r\n}\r\n\r\nTreeNode build_helper(Node lst){\r\n    if(lst==null){\r\n        return null;\r\n    }\r\n    if(lst.next == null){\r\n        return new TreeNode(lst.data,null,null);\r\n    }\r\n    else{\r\n        Node prev =null;\r\n        Node slow = lst;\r\n        Node fast = lst;\r\n        while(fast.next!=null && fast!=null){\r\n            prev = slow;\r\n            slow = slow.next;\r\n            fast = fast.next.next;\r\n        }\r\n        if(prev!=null){prev.next = null;}\r\n\r\n        TreeNode cur = new TreeNode(slow.data, null, null);\r\n\r\n        cur.right = build_helper(slow.next);\r\n        cur.left = build_helper(lst);\r\n        return cur;\r\n    }\r\n}\r\n\r\n\r\nNode node1 = new Node(1,new Node(2, new Node(3,null)));\r\nbuild_helper(node1);",
      "metadata": {
        "language": "java",
        "id": "a2259a74-21c1-46c4-ac2b-18ce4ae68be6",
