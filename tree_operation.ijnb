    {
      "id": "38eb6f25-ec09-4716-ab85-dbc4be8f19d5",
      "cell_type": "code",
      "source": "int get_height(TreeNode root){\r\n    if(root==null){return 0;}\r\n    return (1+Math.max(get_height(root.left), get_height(root.right)));\r\n}\r\nTreeNode right_rotate(TreeNode root){\r\n    TreeNode A = root;\r\n    TreeNode B = root.left;\r\n    TreeNode C = B.right;\r\n    B.right = A;\r\n    A.left = C;\r\n    // update height\r\n    return B;\r\n\r\n}",
      "metadata": {
        "language": "java",
