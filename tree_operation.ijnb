    {
      "id": "500548e1-c3e4-43fa-815b-520c80083793",
      "cell_type": "code",
      "source": "TreeNode get_LCA(TreeNode root, TreeNode p, TreeNode q){\r\n    if(root==null){return null;}\r\n    if(root==p || root==q){\r\n        return root;\r\n    }\r\n    else{\r\n        TreeNode left_LCA = get_LCA(root.left, p, q);\r\n        TreeNode right_LCA = get_LCA(root.right, p, q);\r\n        if(left_LCA!=null && right_LCA!=null){\r\n            return root;\r\n        }\r\n        return ((left_LCA!=null)?left_LCA:right_LCA);\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "id": "500548e1-c3e4-43fa-815b-520c80083793",
        "executionSummary": {
