    {
      "id": "cded407c-d8f1-4829-a2c5-d85d7d65639a",
      "cell_type": "code",
      "source": "TreeNode flatten_tree(TreeNode root){\r\n    if(root==null){return null;}\r\n    else{\r\n        root.left= flatten_tree(root.left);\r\n        root.right = flatten_tree(root.right);\r\n       \r\n        if(root.left!=null){\r\n            TreeNode tmp = root.right;\r\n            root.right = root.left;\r\n            root.left = null;\r\n            TreeNode cur = root.right;\r\n            while(cur.right!=null){\r\n                cur = cur.right;\r\n            }\r\n            cur.right = tmp;\r\n        }\r\n        return root;\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "id": "cded407c-d8f1-4829-a2c5-d85d7d65639a",
        "executionSummary": {
