    {
      "id": "39e47d8f-75f5-42e3-a7ff-d9f989d03543",
      "cell_type": "markdown",
      "source": "Exercise 5: Print the tree using the breadth-first search (BFS)",
      "metadata": {
        "language": "markdown",
        "id": "39e47d8f-75f5-42e3-a7ff-d9f989d03543"
      }
    },
    {
      "id": "ac166f82-a611-40ce-af75-0787d9625f1e",
      "cell_type": "code",
      "source": "import java.util.Queue;\r\nimport java.util.LinkedList;\r\npublic <T> void print_BFS(BinaryTreeNode<T> tree_root){\r\n    Queue<BinaryTreeNode<T>> queue = new LinkedList<>();;\r\n    queue.offer(tree_root);\r\n    while(!queue.isEmpty){\r\n        BinaryTreeNode<T> tmp = queue.poll();\r\n        if(tmp!=null){\r\n            IO.print(tmp.data.toString() + \" \");\r\n            queue.offer(tmp.left);\r\n            queue.offer(tmp.right);\r\n        }\r\n    }\r\n\r\n}",
      "metadata": {
        "language": "java"
      },
      "execution_count": null,
      "outputs": []
    }
  ]
