    {
      "id": "086ca41f-6f9d-4d36-bfd0-7316a31c9174",
      "cell_type": "code",
      "source": "import java.util.Arrays;\r\n\r\n// 1. Hàm đệ quy\r\nvoid print_all_binary_string(int n, int[] incomplete_str, int pos) {\r\n    if (pos == n) {\r\n        System.out.println(Arrays.toString(incomplete_str));\r\n        return;\r\n    }\r\n    for (int i = 0; i <= 1; i++) {\r\n        incomplete_str[pos] = i;\r\n        print_all_binary_string(n, incomplete_str, pos + 1);\r\n    }\r\n}\r\n\r\n// 2. Hàm gọi\r\nvoid print_all_bin_str(int n) {\r\n    int[] arr = new int[n];\r\n    // Bắt đầu từ 0\r\n    print_all_binary_string(n, arr, 0);\r\n}\r\n\r\n// 3. LỆNH CHẠY (Gõ dòng này thì nó mới in ra!)\r\nprint_all_bin_str(3);",
