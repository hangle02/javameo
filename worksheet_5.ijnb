0, 3, 1, 7]\r\n[5, 2, 4, 7, 0, 3, 1, 6]\r\n[5, 2, 6, 1, 3, 7, 0, 4]\r\n[5, 2, 6, 1, 7, 4, 0, 3]\r\n[5, 2, 6, 3, 0, 7, 1, 4]\r\n[5, 3, 0, 4, 7, 1, 6, 2]\r\n[5, 3, 1, 7, 4, 6, 0, 2]\r\n[5, 3, 6, 0, 2, 4, 1, 7]\r\n[5, 3, 6, 0, 7, 1, 4, 2]\r\n[5, 7, 1, 3, 0, 6, 4, 2]\r\n[6, 0, 2, 7, 5, 3, 1, 4]\r\n[6, 1, 3, 0, 7, 4, 2, 5]\r\n[6, 1, 5, 2, 0, 3, 7, 4]\r\n[6, 2, 0, 5, 7, 4, 1, 3]\r\n[6, 2, 7, 1, 4, 0, 5, 3]\r\n[6, 3, 1, 4, 7, 0, 2, 5]\r\n[6, 3, 1, 7, 5, 0, 2, 4]\r\n[6, 4, 2, 0, 5, 7, 1, 3]\r\n[7, 1, 3, 0, 6, 4, 2, 5]\r\n[7, 1, 4, 2, 0, 6, 3, 5]\r\n[7, 2, 0, 5, 1, 4, 6, 3]\r\n[7, 3, 0, 2, 5, 1, 6, 4]\r\n"
