      }
    },
    {
      "id": "8c5aa3f7-b6cc-43ef-91da-bd7fd9b653f6",
      "cell_type": "code",
      "source": "import java.util.Arrays;\r\n\r\n// 1. Hàm đệ quy\r\nvoid print_all_subsets(int n, int index, int[] current_subset) {\r\n   //dung khi chay het so\r\n    if(index > n){\r\n        System.out.println(Arrays.toString(current_subset));\r\n        return;\r\n   }\r\n\r\n   int[] new_subset = Arrays.copyOf(current_subset, current_subset.length + 1);\r\n   new_subset[new_subset.length - 1] = index;\r\n   print_all_subsets(n, index+1, new_subset);\r\n\r\n   print_all_subsets(n, index+1, current_subset);\r\n\r\n   \r\n}\r\n\r\n// 2. Hàm gọi\r\nvoid print_all_sub(int n) {\r\n    int[] arr = new int[0]; // Khởi tạo mảng rỗng\r\n    // Bắt đầu từ 1\r\n    print_all_subsets(n,1, arr);\r\n}\r\n\r\n// 3. LỆNH CHẠY (Gõ dòng này thì nó mới in ra!)\r\nprint_all_sub(4);",
      "metadata": {
        "language": "java",
        "id": "8c5aa3f7-b6cc-43ef-91da-bd7fd9b653f6",
        "executionSummary": {
          "executionOrder": 10,
          "success": true
        }
      },
      "execution_count": 10,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[1, 2, 3, 4]\r\n[1, 2, 3]\r\n[1, 2, 4]\r\n[1, 2]\r\n[1, 3, 4]\r\n[1, 3]\r\n[1, 4]\r\n[1]\r\n[2, 3, 4]\r\n[2, 3]\r\n[2, 4]\r\n[2]\r\n[3, 4]\r\n[3]\r\n[4]\r\n[]\r\n"
          },
          "metadata": {},
          "execution_count": 10
        }
