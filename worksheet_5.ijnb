            "text/plain": "[1, 2, 3, 4]\r\n[1, 2, 4, 3]\r\n[1, 3, 2, 4]\r\n[1, 3, 4, 2]\r\n[1, 4, 2, 3]\r\n[1, 4, 3, 2]\r\n[2, 1, 3, 4]\r\n[2, 1, 4, 3]\r\n[2, 3, 1, 4]\r\n[2, 3, 4, 1]\r\n[2, 4, 1, 3]\r\n[2, 4, 3, 1]\r\n[3, 1, 2, 4]\r\n[3, 1, 4, 2]\r\n[3, 2, 1, 4]\r\n[3, 2, 4, 1]\r\n[3, 4, 1, 2]\r\n[3, 4, 2, 1]\r\n[4, 1, 2, 3]\r\n[4, 1, 3, 2]\r\n[4, 2, 1, 3]\r\n[4, 2, 3, 1]\r\n[4, 3, 1, 2]\r\n[4, 3, 2, 1]\r\n"
          },
