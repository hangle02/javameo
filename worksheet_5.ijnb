      "cell_type": "code",
      "source": "import java.util.Arrays;\r\n\r\nint[] find_possible_values(int[][] matrix, int x, int y){\r\n    int[] arr_1 = new int[0];\r\n    int[] arr_2 = new int[0];\r\n    int[] miss_x = find_row_missing(matrix, 1, arr_1, x);\r\n    int[] miss_y = find_col_missing(matrix, 1, arr_2, y);\r\n    int[] r = check_same_value(miss_x, miss_y);\r\n    return r;\r\n\r\n}\r\n\r\nint[] find_row_missing(int[][] matrix, int index, int[] current_num, int x){\r\n    if (index>9){\r\n        return current_num;\r\n    }\r\n    for (int i=0; i<9; i++ ){\r\n        if(matrix[x][i] == index){\r\n            find_row_missing(matrix, index+1, current_num, x);\r\n        }\r\n    }\r\n    int[] new_num = Arrays.copyOf(current_num, current_num.length + 1);\r\n    new_num[new_num.length-1] = index;\r\n    find_row_missing(matrix, index+1, new_num, x);\r\n}\r\n\r\nint[] find_col_missing(int[][] matrix, int index, int[] current_num, int y){\r\n    if (index>9){\r\n        return current_num;\r\n    }\r\n    for (int i=0; i<9; i++ ){\r\n        if(matrix[i][y] == index){\r\n            find_col_missing(matrix, index+1, current_num, y);\r\n        }\r\n    }\r\n    int[] new_num = Arrays.copyOf(current_num, current_num.length + 1);\r\n    new_num[new_num.length-1] = index;\r\n    find_col_missing(matrix, index+1, new_num, y);\r\n}\r\n\r\nint[] check_same_value(int[] row, int[] col){\r\n    int n=0;\r\n    for(int i=0; i< row.length; i++){\r\n        for(int j=0; j<col.length; j++){\r\n            if(col[j]==row[i]){\r\n                n= n+1;\r\n            }\r\n        }\r\n    }\r\n    int[] same = new int[n];\r\n    for(int k=0; k< n; k++){\r\n        for(int i=0; i< row.length; i++){\r\n            for(int j=0; j<col.length; j++){\r\n            if(col[j]==row[i]){\r\n                same[k]=col[j];\r\n            }\r\n        }\r\n    }}\r\n    return same;\r\n}\r\n\r\nint[][] matrix_1 = {{0, 5, 0, 0, 0, 2, 0, 0, 6},\r\n{0, 8, 0, 0, 0, 6, 7, 0, 3},\r\n{0, 0, 0, 7, 4, 0, 0, 0, 8},\r\n{6, 7, 0, 9, 8, 0, 0, 0, 0},\r\n{0, 3, 1, 0, 5, 0, 6, 0, 9},\r\n{0, 0, 0, 0, 0, 3, 8, 2, 0},\r\n{0, 0, 0, 0, 0, 0, 1, 8, 0},\r\n{0, 0, 0, 3, 0, 0, 0, 0, 2},\r\n{9, 2, 0, 5, 0, 0, 0, 7, 0}};\r\n\r\nfind_possible_values(matrix_1,0,0);\r\n",
