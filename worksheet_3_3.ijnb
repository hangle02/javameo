    {
      "id": "5e65950d-d8d1-4921-842b-d50063add80b",
      "cell_type": "markdown",
      "source": "# Question 3: Implement the selection sort",
      "metadata": {
        "language": "markdown",
        "id": "5e65950d-d8d1-4921-842b-d50063add80b"
      }
    },
    {
      "id": "551deaf7-c6f6-4c0f-8656-83ccf8a07378",
      "cell_type": "code",
      "source": "import java.util.Arrays;\nvoid selection_sort(int[] arr) {\n    int n =arr.length;\n    for(int i=0; i<n-1; i++ ){\n        int minIndex = i;\n        for(int j = i+1; j<n; j++){\n            if(arr[j]<arr[minIndex]){\n                minIndex = j;\n            }\n        }\n        int temp = arr[minIndex];\n        arr[minIndex] = arr[i];\n        arr[i] = temp;\n    }\n}\n\n// Unit test\nint[] input_arr = {5, 6, 1, 4, 2, 3};\nint[] output_arr = {1,2,3,4,5,6};\ninsertion_sort(input_arr);\nIO.println(Arrays.equals(input_arr, output_arr));",
      "metadata": {
        "language": "java",
        "id": "551deaf7-c6f6-4c0f-8656-83ccf8a07378",
