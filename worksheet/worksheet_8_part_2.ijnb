    {
      "id": "3f2b293a-87eb-42bf-940f-96a39fa98c8c",
      "cell_type": "code",
      "source": "public boolean is_BST(BinaryTreeNode<Integer> root) {\r\n    // Gọi hàm phụ trợ (Helper), ban đầu giới hạn Min và Max đều là null (không có giới hạn)\r\n    return is_BST_Helper(root, null, null);\r\n}\r\n\r\nprivate boolean is_BST_Helper(BinaryTreeNode<Integer> node, Integer min, Integer max) {\r\n    // Base case: Cây rỗng là một BST hợp lệ\r\n    if (node == null) {\r\n        return true;\r\n    }\r\n\r\n    // Kiểm tra xem Node hiện tại có phá vỡ giới hạn Min/Max hay không\r\n    if (min != null && node.data.compareTo(min) <= 0) {\r\n        return false; // Phải lớn hơn giá trị Min\r\n    }\r\n    if (max != null && node.data.compareTo(max) >= 0) {\r\n        return false; // Phải nhỏ hơn giá trị Max\r\n    }\r\n\r\n    // Đệ quy kiểm tra 2 nhánh:\r\n    // 1. Sang trái: Cập nhật Max = giá trị node hiện tại\r\n    // 2. Sang phải: Cập nhật Min = giá trị node hiện tại\r\n    return is_BST_Helper(node.left, min, node.data) && \r\n           is_BST_Helper(node.right, node.data, max);\r\n}",
      "metadata": {
        "language": "java",
        "id": "3f2b293a-87eb-42bf-940f-96a39fa98c8c",
