    {
      "id": "413e49e7-9ec5-44b5-ba03-429bdcfef889",
      "cell_type": "code",
      "source": "import java.util.Arrays;\nvoid bubble_sort(int[] arr) {\n    int[] r_arr;\n    if (arr.length<2|| arr == null){\n        return;\n    }\n    int temp=0;\n    for (int k=0; k<arr.length-1; k++){\n        for (int i=0; i < arr.length-1-k; i++){\n            if (arr[i]> arr[i+1]){\n                temp = arr[i];\n                arr[i]=arr[i+1];\n                arr[i+1] = temp;\n            }    \n        }\n    }\n}\n// Unit test\nint[] input_arr = {5, 6, 1, 4, 2, 3};\nint[] output_arr = {1,2,3,4,5,6};\nbubble_sort(input_arr);\nIO.println(Arrays.equals(input_arr, output_arr));",
      "metadata": {
        "language": "java",
