    {
      "id": "338d5af1-cbf1-4942-89b3-929cbaf54cc0",
      "cell_type": "code",
      "source": "class AVLTreeNode<T> {\n    T key;\n    AVLTreeNode<T> left, right;\n    int height;\n\n    // constructor\n    public AVLTreeNode(T key_, AVLTreeNode<T> left_, AVLTreeNode<T> right_) {\n        height = 0;\n        key = key_;\n        left = left_;\n        right = right_;\n    }\n    void update_height() {\n        // Write your code here\n        if (left != null)\n            left.update_height();\n        if (right != null)\n            right.update_height();\n        \n        if (left == null && right == null)\n            height = 0;\n        else\n            height = 1 + Math.max((left == null)? 0: left.height, (right == null)? 0:right.height);\n    }\n}\n\nAVLTreeNode<Integer> n1 = new AVLTreeNode<Integer>(1, null, null);\nn1.update_height();\nIO.println(n1.height == 0);\n\nAVLTreeNode<Integer> n2 = new AVLTreeNode<Integer>(2, \n    new AVLTreeNode<Integer>(1, null, null), \n    null);\nn2.update_height();\nIO.println(n2.height == 1);\n\nAVLTreeNode<Integer> n3 = new AVLTreeNode<Integer>(2, \n    new AVLTreeNode<Integer>(1, null, null), \n    new AVLTreeNode<Integer>(3, null, null));\nn3.update_height();\nIO.println(n3.height == 1);\n\nAVLTreeNode<Integer> n4 = new AVLTreeNode<Integer>(3, \n    new AVLTreeNode<Integer>(1, null, new AVLTreeNode<Integer>(2, null, null)), \n    new AVLTreeNode<Integer>(4, null, null));\nn4.update_height();\nIO.println(n4.height == 2);\n\nAVLTreeNode<Integer> n4 = new AVLTreeNode<Integer>(4, \n    new AVLTreeNode<Integer>(1, null, new AVLTreeNode<Integer>(3, new AVLTreeNode<Integer>(2, null, null), null)), \n    null);\nn4.update_height();\nIO.println(n4.height == 3);",
