    {
      "id": "72ced47e-6532-4e15-a8a4-c0c86916e453",
      "cell_type": "markdown",
      "source": "# Q&A\r\n1. Reverse a stack using queue? YES\r\n2. Delete a middle element of a stack? YES  \r\n  - Using other stack or queue\r\n  \r\n3. Implement a Queue using Stack?  \r\n  - cannot use a single stack\r\n  - but we can using 2 stack (stackin and stackout)\r\n\r\n--> 1 Queue = 2 Stack \r\n\r\n4. Implement a Stack using Queue?  \r\n  - \r\n\r\n5. Implement two Stack in an Array?  \r\n  - YES, JUST CUT THE ARRAY IN HALF\r\n\r\n6. Sort a stack using another stack?  \r\n  - We need to use some more free variable\r\n  \r\n\r\n\r\n",
      "metadata": {
        "language": "markdown",
        "id": "72ced47e-6532-4e15-a8a4-c0c86916e453"
      }
    },
    {
      "id": "52105f50-2668-4742-924f-e189187f2c84",
      "cell_type": "code",
      "source": "import java.util.Stack;\r\n\r\npublic class QueueUsingStack {\r\n    private Stack<Integer> stackIn;\r\n    private Stack<Integer> stackOut;\r\n\r\n    public QueueUsingStack() {\r\n        stackIn = new Stack<>();\r\n        stackOut = new Stack<>();\r\n    }\r\n\r\n    // Thêm phần tử vào cuối hàng đợi (O(1))\r\n    public void push(int x) {\r\n        stackIn.push(x);\r\n    }\r\n\r\n    // Lấy và xóa phần tử ở đầu hàng đợi (Amortized O(1))\r\n    public int pop() {\r\n        shiftStacks();\r\n        return stackOut.pop();\r\n    }\r\n\r\n    // Xem phần tử ở đầu hàng đợi mà không xóa (Amortized O(1))\r\n    public int peek() {\r\n        shiftStacks();\r\n        return stackOut.peek();\r\n    }\r\n\r\n    // Kiểm tra hàng đợi có trống không\r\n    public boolean empty() {\r\n        return stackIn.isEmpty() && stackOut.isEmpty();\r\n    }\r\n\r\n    // Hàm phụ trợ: Đổ dữ liệu từ In sang Out nếu Out đang trống\r\n    private void shiftStacks() {\r\n        if (stackOut.isEmpty()) {\r\n            while (!stackIn.isEmpty()) {\r\n                stackOut.push(stackIn.pop());\r\n            }\r\n        }\r\n    }\r\n}\r\n   \r\n        QueueUsingStack queue = new QueueUsingStack();\r\n        queue.push(1);\r\n        queue.push(2);\r\n        System.out.println(\"Lấy ra đầu Queue: \" + queue.pop()); // Trả về 1\r\n        queue.push(3);\r\n        System.out.println(\"Xem đầu Queue: \" + queue.peek());   // Trả về 2\r\n ",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 5,
          "success": true
        }
      },
      "execution_count": 5,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "Lấy ra đầu Queue: 1\r\nXem đầu Queue: 2\r\n"
          },
          "metadata": {},
          "execution_count": 5
        }
      ]
    },
    {
      "id": "474ec591-ffd6-4f0d-887d-182250947a29",
      "cell_type": "code",
      "source": "import java.util.LinkedList;\r\nimport java.util.Queue;\r\n\r\npublic class StackUsingQueue {\r\n    private Queue<Integer> queue;\r\n\r\n    public StackUsingQueue() {\r\n        // Trong Java, LinkedList là class phổ biến nhất để triển khai Queue\r\n        queue = new LinkedList<>();\r\n    }\r\n\r\n    // Thêm phần tử lên đỉnh Stack (O(n))\r\n    public void push(int x) {\r\n        queue.add(x);\r\n        int size = queue.size();\r\n        \r\n        // Xoay vòng: Rút các phần tử cũ ra và nhét lại vào đuôi\r\n        for (int i = 0; i < size - 1; i++) {\r\n            queue.add(queue.remove());\r\n        }\r\n    }\r\n\r\n    // Lấy và xóa phần tử ở đỉnh Stack (O(1))\r\n    public int pop() {\r\n        return queue.remove();\r\n    }\r\n\r\n    // Xem phần tử ở đỉnh Stack mà không xóa (O(1))\r\n    public int top() {\r\n        return queue.peek();\r\n    }\r\n\r\n    // Kiểm tra Stack có trống không\r\n    public boolean empty() {\r\n        return queue.isEmpty();\r\n    }\r\n}\r\n        StackUsingQueue stack = new StackUsingQueue();\r\n        stack.push(1);\r\n        stack.push(2);\r\n        System.out.println(\"Lấy ra đỉnh Stack: \" + stack.pop()); // Trả về 2\r\n        stack.push(3);\r\n        System.out.println(\"Xem đỉnh Stack: \" + stack.top());    // Trả về 3\r\n\r\n",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 4,
          "success": true
        }
      },
      "execution_count": 4,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "Lấy ra đỉnh Stack: 2\r\nXem đỉnh Stack: 3\r\n"
          },
          "metadata": {},
          "execution_count": 4
        }
      ]
    }
