    {
      "id": "14abe382-6bc0-415a-9e84-1d203cce96ec",
      "cell_type": "code",
      "source": "import java.util.LinkedList;\nimport java.util.HashMap;\n\npublic interface Graph {\n    public void add_vertex(int node_id);\n    public void add_edge(int src, int dest, int weight);\n    public int adjacent(int src, int dest);\n    public LinkedList<Integer> neighbors(int node);\n}\n\npublic class Adjacent_Mat_Graph implements Graph {\n    int[][] adj_matrix;\n    int node_num;\n    public final int NO_CONNECTION = 0;\n    public static int WHITE = 0; // Unvisited, currently in the stack, but not on the current path\n    public static int GREY = 1; // In the current path\n    public static int BLACK = 2; // Visited already and has been popped out\n    \n    Adjacent_Mat_Graph (int max_size) {\n        adj_matrix = new int[max_size][max_size];\n        for (int src = 0; src < max_size; src++)\n            for (int dest = 0; dest < max_size; dest++)\n                adj_matrix[src][dest] = NO_CONNECTION;    \n            \n    }\n\n    public void add_vertex(int node_id) {\n        node_num++;\n        if (node_num > adj_matrix.length) {\n            // We have to migrate and resize the adj_mat\n            IO.println(\"We have to migrate and resize the adj_mat\"); \n        }\n    }\n\n    public void add_edge(int src, int dest, int weight) {\n        adj_matrix[src][dest] = weight;\n    }\n\n    public int adjacent(int src, int dest) {\n        return adj_matrix[src][dest];\n    }\n\n    public LinkedList<Integer> neighbors(int node) {\n        LinkedList<Integer> tmp = new LinkedList<Integer>();\n        for (int dest = 0; dest < node_num; dest++)\n            if (adj_matrix[node][dest] != NO_CONNECTION)\n                tmp.add(dest);\n\n        return tmp;\n    }\n\n    public void DFS_(int source, boolean[] is_visited) {\n        is_visited[source] = true;\n        // To debug\n        IO.println(source);\n        LinkedList<Integer> neighbors = neighbors(source);\n        for (int neighbor: neighbors)\n            if (!is_visited[neighbor])\n                DFS_(neighbor, is_visited); \n\n\n    }\n\n    public void DFS(int source) {\n        // Need something to check if source node has been visited\n        boolean is_visited[] = new boolean[node_num];\n        for (int v = 0; v < node_num; v++)\n            is_visited[v] = false;\n        DFS_(source, is_visited);\n    }\n\n    public void BFS(int source) {\n        boolean is_visited[] = new boolean[node_num];\n        for (int v = 0; v < node_num; v++)\n            is_visited[v] = false;\n\n        LinkedList<Integer> waiting_queue = new LinkedList<>();\n        waiting_queue.addFirst(source);\n\n        while(!waiting_queue.isEmpty()) {\n            int current_node = waiting_queue.removeLast();\n            if (!is_visited[current_node]) {\n                is_visited[current_node] = true;\n                // for debugging\n                IO.println(current_node);\n\n                LinkedList<Integer> neighbors = neighbors(current_node);\n                for (int neighbor: neighbors)\n                    waiting_queue.addFirst(neighbor);\n            }                \n        }\n    }\n\n    public boolean _is_cyclic_(int source, int[] color) {\n        for (int v = 0; v < node_num; v++)\n            if (color[v] == GREY && adjacent(source, v) != NO_CONNECTION)\n                return true;\n        color[source] = GREY;\n        // To debug\n        //IO.println(source);\n        LinkedList<Integer> neighbors = neighbors(source);\n        for (int neighbor: neighbors)\n            if (color[neighbor] == WHITE)\n                if (_is_cyclic_(neighbor, color))\n                    return true; \n        color[source] = BLACK;\n        return false;\n    }\n\n    public boolean is_cyclic() {  \n        for (int source = 0; source < node_num; source++) {\n            int color[] = new int[node_num];\n            for (int v = 0; v < node_num; v++)\n                color[v] = WHITE;\n            if (_is_cyclic_(source, color))\n                return true;\n        }\n        return false;\n    }    \n\n    /*public boolean is_cyclic() {\n        int color[] = new int[node_num];\n        for (int v = 0; v < node_num; v++)\n            color[v] = WHITE;\n\n        int source = 0;\n\n        LinkedList<Integer> waiting_stack = new LinkedList<>();\n        waiting_stack.addFirst(source);\n\n        while(!waiting_stack.isEmpty()) {\n            int current_node = waiting_stack.removeFirst();\n            if (color[current_node] != BLACK) {\n                //color[current_node] = ?;\n                // for debugging\n                // IO.println(current_node);\n\n                LinkedList<Integer> neighbors = neighbors(current_node);\n                for (int neighbor: neighbors)\n                    if (color[neighbor] == WHITE) {\n                        waiting_stack.addFirst(neighbor);\n                    }\n                color[current_node] = BLACK;\n            }\n            else { // color[current_node] == BLACK\n                IO.print(\"BLACK Node!\");\n            }\n        }\n    }*/\n}\n\n\nAdjacent_Mat_Graph graph_1 = new Adjacent_Mat_Graph(100);\n               \nfor (int node_id = 0; node_id < 7; node_id++)\n    graph_1.add_vertex(node_id);\nstatic int CONNECTION = 1;\n\ngraph_1.add_edge(0, 1, CONNECTION);\ngraph_1.add_edge(1, 2, CONNECTION);\ngraph_1.add_edge(2, 3, CONNECTION);\ngraph_1.add_edge(0, 4, CONNECTION);\ngraph_1.add_edge(4, 5, CONNECTION);\ngraph_1.add_edge(5, 6, CONNECTION);\ngraph_1.add_edge(5, 2, CONNECTION);\ngraph_1.add_edge(6, 3, CONNECTION);\n\n\nAdjacent_Mat_Graph graph_2 = new Adjacent_Mat_Graph(100);\n               \nfor (int node_id = 0; node_id < 7; node_id++)\n    graph_2.add_vertex(node_id);\nstatic int CONNECTION = 1;\n\ngraph_2.add_edge(0, 1, CONNECTION);\ngraph_2.add_edge(1, 2, CONNECTION);\ngraph_2.add_edge(2, 3, CONNECTION);\ngraph_2.add_edge(0, 4, CONNECTION);\ngraph_2.add_edge(4, 5, CONNECTION);\ngraph_2.add_edge(6, 5, CONNECTION);\ngraph_2.add_edge(5, 2, CONNECTION);\ngraph_2.add_edge(3, 6, CONNECTION);\n\n\nIO.println(graph_1.is_cyclic());\nIO.println(graph_2.is_cyclic());\n",
