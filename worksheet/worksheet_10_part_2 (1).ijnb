      "cell_type": "code",
      "source": "import java.util.HashMap;\r\n\r\nHashMap<String, Integer> node_name_to_id = new HashMap<>();\r\n    node_name_to_id.put(\"Linear Alg\", 0);\r\n    node_name_to_id.put(\"Discrete Math\", 1);\r\n    node_name_to_id.put(\"CS1\",2);\r\n    node_name_to_id.put(\"CS2\",3);\r\n    node_name_to_id.put(\"DST\",4);\r\n    node_name_to_id.put(\"Com ord\",5);\r\n    node_name_to_id.put(\"Algorithms\",6);\r\n    node_name_to_id.put(\"OS\",7);\r\n    node_name_to_id.put(\"GRAD\",8);\r\n",
