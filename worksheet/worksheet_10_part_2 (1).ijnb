      "id": "6d46528a-289a-47f2-891d-edfddf80713a",
      "cell_type": "code",
      "source": "import java.util.LinkedList;\nimport java.util.HashMap;\n\npublic interface Graph {\n    public void add_vertex(int node_id);\n    public void add_edge(int src, int dest, int weight);\n    public int adjacent(int src, int dest);\n    public LinkedList<Integer> neighbors(int node);\n}\n\npublic class Adjacent_Mat_Graph implements Graph {\n    int[][] adj_matrix;\n    int node_num;\n    public final int NO_CONNECTION = 0;\n\n    Adjacent_Mat_Graph (int max_size) {\n        adj_matrix = new int[max_size][max_size];\n        for (int src = 0; src < max_size; src++)\n            for (int dest = 0; dest < max_size; dest++)\n                adj_matrix[src][dest] = NO_CONNECTION;    \n            \n    }\n\n    public void add_vertex(int node_id) {\n        node_num++;\n        if (node_num > adj_matrix.length) {\n            // We have to migrate and resize the adj_mat\n            IO.println(\"We have to migrate and resize the adj_mat\"); \n        }\n    }\n\n    public void add_edge(int src, int dest, int weight) {\n        adj_matrix[src][dest] = weight;\n    }\n\n    public int adjacent(int src, int dest) {\n        return adj_matrix[src][dest];\n    }\n\n    public LinkedList<Integer> neighbors(int node) {\n        LinkedList<Integer> tmp = new LinkedList<Integer>();\n        for (int dest = 0; dest < node_num; dest++)\n            if (adj_matrix[node][dest] != NO_CONNECTION)\n                tmp.add(dest);\n\n        return tmp;\n    }\n\n    public void find_component (int[] component_ids) {\n        int HOMELESS = 0;\n        //component_ids = new int[node_num];\n        for (int v = 0; v < node_num; v++)\n            component_ids[v] = HOMELESS; // 0: unassigned component id\n\n        boolean is_done = false;\n        int current_component_id = 1;\n        boolean[] visited = new boolean[node_num];\n        while (!is_done) {\n            LinkedList<Integer> waiting_queue = new LinkedList<>();\n            is_done = true;\n            for (int v = 0; v < node_num; v++){\n                if(!visited[v]){\n                    if (component_ids[v] == HOMELESS) {\n                        is_done = false;\n                        waiting_queue.addFirst(v);\n                        visited[v] = true;\n                        break;\n                    }\n                }\n            }\n            while(!waiting_queue.isEmpty()) {\n                int current_node = waiting_queue.removeLast();\n                if (component_ids[current_node] == HOMELESS) {\n                    component_ids[current_node] = current_component_id;\n                    // for debugging\n                    //IO.println(current_node);\n                    LinkedList<Integer> neighbors = neighbors(current_node);\n                    for (int neighbor: neighbors)\n                        if(!visited[neighbor]){\n                            visited[neighbor] = true;\n                            waiting_queue.addFirst(neighbor);\n                            \n                        }\n                }                \n            }\n            current_component_id++;       \n        }\n    }\n}\n\n\nAdjacent_Mat_Graph graph_1 = new Adjacent_Mat_Graph(100);\n               \nfor (int node_id = 1; node_id <= 13; node_id++)\n    graph_1.add_vertex(node_id);\nstatic int CONNECTION = 1;\n\ngraph_1.add_edge(1, 2, CONNECTION); graph_1.add_edge(2, 1, CONNECTION);\ngraph_1.add_edge(1, 5, CONNECTION); graph_1.add_edge(5, 1, CONNECTION);\ngraph_1.add_edge(1, 6, CONNECTION); graph_1.add_edge(6, 1, CONNECTION);\ngraph_1.add_edge(2, 6, CONNECTION); graph_1.add_edge(6, 2, CONNECTION);\n\ngraph_1.add_edge(3, 4, CONNECTION); graph_1.add_edge(4, 3, CONNECTION);\ngraph_1.add_edge(7, 4, CONNECTION); graph_1.add_edge(4, 7, CONNECTION);\ngraph_1.add_edge(4, 9, CONNECTION); graph_1.add_edge(9, 4, CONNECTION);\ngraph_1.add_edge(4, 8, CONNECTION); graph_1.add_edge(8, 4, CONNECTION);\ngraph_1.add_edge(8, 10, CONNECTION); graph_1.add_edge(10, 8, CONNECTION);\ngraph_1.add_edge(9, 10, CONNECTION); graph_1.add_edge(10, 9, CONNECTION);\n\ngraph_1.add_edge(12, 13, CONNECTION); graph_1.add_edge(13, 12, CONNECTION);\n\nint[] component_ids = new int[graph_1.node_num];\ngraph_1.find_component(component_ids);\n\nfor (int i = 0; i < component_ids.length; i++) {\n    IO.println(component_ids[i]);    \n}",
