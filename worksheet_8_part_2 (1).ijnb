    {
      "id": "d710d264-a1d4-4269-a86e-fb5ee8f535cd",
      "cell_type": "markdown",
      "source": "Exercise 1: Run the code below to see how to create a binary and print it out ",
      "metadata": {
        "language": "markdown",
        "id": "d710d264-a1d4-4269-a86e-fb5ee8f535cd"
      }
    },
    {
      "id": "7b4d2c4c-097a-4f10-9b2b-f6bf81f8d6a6",
      "cell_type": "code",
      "source": "import java.util.LinkedList;\n\nclass BinaryTreeNode<T> {\n    T key;\n    BinaryTreeNode<T> left, right;\n\n    // constructor\n    public BinaryTreeNode(T key_, BinaryTreeNode<T> left_, BinaryTreeNode<T> right_) {\n        key = key_;\n        left = left_;\n        right = right_;\n    }\n}\n\nclass VisualTreeNode<T> {\n    BinaryTreeNode<T> tree_node;\n    int depth;  // root depth = 0\n    int index;  // from 0 to 2^depth - 1\n    public VisualTreeNode(BinaryTreeNode<T> tree_node, int depth, int index) {\n        this.tree_node = tree_node;\n        this.depth = depth;\n        this.index = index;\n    }\n}\n\nclass BinaryTree<T>{\n    BinaryTreeNode<T> root;\n    public BinaryTree(BinaryTreeNode<T> root_) {\n        root = root_;\n    }\n\n    public void print() {\n        LinkedList<VisualTreeNode<T>> queue = new LinkedList<VisualTreeNode<T>>();\n        LinkedList<VisualTreeNode<T>> result_queue = new LinkedList<VisualTreeNode<T>>();\n        queue.add(new VisualTreeNode<T>(root, 0, 0));\n        int max_depth = 0;\n        while (!queue.isEmpty()){\n            VisualTreeNode<T> tmp = queue.remove();\n            result_queue.add(tmp);\n            if (max_depth < tmp.depth)\n                max_depth = tmp.depth;\n            if (tmp.tree_node.left != null)\n                queue.add(new VisualTreeNode<T>(tmp.tree_node.left, tmp.depth + 1, 2*tmp.index));\n            if (tmp.tree_node.right != null)\n                queue.add(new VisualTreeNode<T>(tmp.tree_node.right, tmp.depth + 1, 2*tmp.index + 1));\n        }\n        \n        int space_num = 4; // at the leaf node\n        int current_depth = 0;\n        String line = \"\", path = \"\";\n        int current_line_pos = 0, current_path_pos = 0;\n        while (!result_queue.isEmpty()) {\n            VisualTreeNode<T> tmp = result_queue.remove();\n            if (tmp.depth > current_depth) {\n                current_depth++;\n                if (current_depth > 1)\n                    System.out.println(path);\n                System.out.println(line);\n                line = path = \"\";\n                current_line_pos = current_path_pos = 0;\n            }\n            // Update the line (i.e. tree node info)\n            int padding = (int) Math.round(((Math.pow(2, max_depth - tmp.depth) - 1)/2)*space_num);\n            int width = (int) Math.pow(2, max_depth - tmp.depth)*space_num;\n            int line_pos = padding + tmp.index*width;\n            for (int i = current_line_pos; i <= line_pos; i++)\n                line += \" \";\n            //line += Integer.toString(tmp.tree_node.key);\n            line += String.valueOf(tmp.tree_node.key);\n            current_line_pos = line_pos + 1;\n            // Update the path (i.e. \"/\" and \"\\\" to connect nodes)\n            int parent_index = (int)Math.round((tmp.index - 0.5)/2);\n            int parent_padding = padding + width/2;\n            int parent_width = 2*width;\n            int path_pos = (line_pos + parent_padding + parent_index*parent_width)/2;\n            for (int i = current_path_pos; i <= path_pos; i++)\n                path += \" \";\n            path += ((tmp.index % 2 == 0)? \"/\":\"\\\\\");\n            current_path_pos = path_pos + 1; \n            if (result_queue.isEmpty()) {\n                if (current_depth > 0)\n                    System.out.println(path);\n                System.out.println(line);\n            } \n        }\n    }\n}\n\n\nBinaryTreeNode<Integer> n2 = new BinaryTreeNode<Integer>(2, null, new BinaryTreeNode<Integer>(-2, null, null));\nBinaryTreeNode<Integer> n4 = new BinaryTreeNode<Integer>(4, new BinaryTreeNode<Integer>(3, null, null), new BinaryTreeNode<Integer>(7, null, null));\nBinaryTreeNode<Integer> root = new BinaryTreeNode<Integer>(1, n2, n4);\nBinaryTree<Integer> my_tree = new BinaryTree<Integer>(root);\nmy_tree.print();\n",
      "metadata": {
        "language": "java",
        "id": "7b4d2c4c-097a-4f10-9b2b-f6bf81f8d6a6",
