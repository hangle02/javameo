    {
      "id": "42a5bb6d-0a3d-45a9-be69-c94ad1ffbdd2",
      "cell_type": "code",
      "source": "int[] arr1 = {1,2,3};\r\nint[] arr2 = arr1;\r\nint[] arr3 = {1,2,3};\r\nIO.println(arr1==arr2);\r\nIO.println(arr1.equals(arr3));\r\nIO.println(Arrays.equals(arr3,arr1));\r\nIO.println(arr3==arr2);\r\n\r\nIO.println(\"\");\r\n\r\nboolean compare(int[] arr_1, int[] arr_2){\r\n    if (arr_1==null && arr_2 == null){return true;}\r\n    if (arr_1 != null || arr_2 ==null){return false; }\r\n    int len1 = arr_1.length;\r\n    int len2 = arr_2.length;\r\n    if (len1!=len2){return false;}\r\n    for (int i=0; i< len1; i++){\r\n        if (arr_1[i]!=arr_2[i]){\r\n            return false;\r\n        }\r\n    }\r\n    return true;\r\n}\r\n\r\nint[] arr4;\r\n\r\nIO.println(compare(arr1, arr4));\r\n",
      "metadata": {
        "language": "java",
        "id": "42a5bb6d-0a3d-45a9-be69-c94ad1ffbdd2",
        "executionSummary": {
          "executionOrder": 10,
          "success": true
        }
      },
      "execution_count": 10,
      "outputs": [
