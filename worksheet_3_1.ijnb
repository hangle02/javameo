    {
      "id": "eb1da725-566b-4ec3-b930-34c26230cb8f",
      "cell_type": "code",
      "source": "import java.util.Random;\r\n//Array of 9 students\r\nString[] students_ = {\r\n        \"200102\", \"210206\", \"210230\", \r\n        \"220221\", \"220027\", \"220050\", \r\n        \"220216\", \"230248\", \"230036\"\r\n};\r\n\r\n\r\n void assign_stu(String[] students){\r\n    Random rand = new Random();\r\n    for (int i=0; i<students.length; i++){\r\n        int ran_index = rand.nextInt(students.length);\r\n        String student = students[i];\r\n        students[i] = students[ran_index];\r\n        students[ran_index] = student;\r\n    }\r\n    IO.println(students[0]+ \" \" + students[1]+ \" \"+ students[2]);\r\n    IO.println(students[3]+ \" \" + students[4]+ \" \"+ students[5]);\r\n    IO.println(students[6]+ \" \" + students[7]+ \" \"+ students[8]);\r\n}\r\n\r\nassign_stu(students_);\r\n",
      "metadata": {
        "language": "java",
        "id": "eb1da725-566b-4ec3-b930-34c26230cb8f",
        "executionSummary": {
          "executionOrder": 29,
          "success": true
        }
      },
      "execution_count": 29,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "210206 210230 230248\r\n200102 220050 230036\r\n220027 220216 220221\r\n"
          },
          "metadata": {},
          "execution_count": 29
        }
      ]
    },
    {
      "id": "816fa6ee-dcdd-4350-9a6f-604b0ebca533",
      "cell_type": "code",
      "source": "import java.util.Random;\r\nString[] students_ = {\r\n        \"200102\", \"210206\", \"210230\", \r\n        \"220221\", \"220027\", \"220050\", \r\n        \"220216\", \"230248\", \"230036\"\r\n};\r\n\r\nint[] group1;\r\nint[] group2;\r\nint[] group3;\r\n\r\nRandom rand = new Random();\r\n\r\nfor (int i=0; i<100; i++){\r\n    int pos1 = rand.nextInt(students.length);\r\n    int pos2 = rand.nextInt(students.length);\r\n    String temp = students[pos1];\r\n    students[pos1] = students[pos2];\r\n    students[pos2] = temp;\r\n}\r\n\r\nIO.println(\"First group\");\r\nfor (int i=0; i<3; i++){\r\n    IO.println(students[i]);\r\n}\r\nIO.println(\"Second group\");\r\nfor (int i=3; i<6; i++){\r\n    IO.println(students[i]);\r\n}\r\nIO.println(\"Third group\");\r\nfor (int i=6; i<9; i++){\r\n    IO.println(students[i]);\r\n}",
