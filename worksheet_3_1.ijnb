    },
    {
      "id": "55c8d848-a438-44e8-b6d9-4495daf3b34d",
      "cell_type": "markdown",
      "source": "# Question 6: \r\nBINARY SORT",
      "metadata": {
        "language": "markdown",
        "id": "55c8d848-a438-44e8-b6d9-4495daf3b34d"
      }
    },
    {
      "id": "ce74adba-4e31-4a11-b1ee-84cb5d6fbf3a",
      "cell_type": "code",
      "source": "int binary_search(int[] arr, int target){\r\n    if (arr == null){ return -1;}\r\n    int left =0;\r\n    int right = arr.length -1;\r\n    while(left<=right){\r\n        //int mid = left+ (-left+right)/2;\r\n        int mid = (left+right)/2;\r\n        if(target == arr[mid]){\r\n            return mid;\r\n        }\r\n        if(target< arr[mid]){\r\n            right = mid-1;\r\n        }\r\n        if(target > arr[mid]){\r\n            left = mid +1;\r\n        }    \r\n    }\r\n    return -1;\r\n}\r\n\r\nint[] arr_1;\r\nint[] arr_2 = {1, 2, 3, 4, 6, 10, 20, 50};\r\nIO.println(binary_search(arr_1, 1) == -1);\r\nIO.println(binary_search(arr_1, 2) == -1);\r\nIO.println(binary_search(arr_2, 1) == 0);\r\nIO.println(binary_search(arr_2, 4) == 3);\r\nIO.println(binary_search(arr_2, 0) == -1);\r\nIO.println(binary_search(arr_2, 15) == -1);\r\nIO.println(binary_search(arr_2, 60) == -1);",
      "metadata": {
        "language": "java",
        "id": "ce74adba-4e31-4a11-b1ee-84cb5d6fbf3a",
        "executionSummary": {
          "executionOrder": 11,
          "success": true
        }
      },
      "execution_count": 11,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "true\r\ntrue\r\ntrue\r\ntrue\r\ntrue\r\ntrue\r\ntrue\r\n"
          },
          "metadata": {},
          "execution_count": 11
        }
      ]
    },
    {
      "id": "37025965-56db-41e6-8ce9-2260b2073785",
      "cell_type": "code",
      "source": "int binary_search(int[] arr, int targe, int left=0, int right =1){\r\n    if (arr == null){ return -1;}\r\n    int left =0;\r\n    int right = arr.length -1;\r\n    while(left<=right){\r\n        //int mid = left+ (-left+right)/2;\r\n        int mid = (left+right)/2;\r\n        if(target == arr[mid]){\r\n            return mid;\r\n        }\r\n        if(target< arr[mid]){\r\n            right = mid-1;\r\n        }\r\n        if(target > arr[mid]){\r\n            left = mid +1;\r\n        }    \r\n    }\r\n    return -1;\r\n}\r\n\r\nint[] arr_1;\r\nint[] arr_2 = {1, 2, 3, 4, 6, 10, 20, 50};\r\nIO.println(binary_search(arr_1, 1) == -1);\r\nIO.println(binary_search(arr_1, 2) == -1);\r\nIO.println(binary_search(arr_2, 1) == 0);\r\nIO.println(binary_search(arr_2, 4) == 3);\r\nIO.println(binary_search(arr_2, 0) == -1);\r\nIO.println(binary_search(arr_2, 15) == -1);\r\nIO.println(binary_search(arr_2, 60) == -1);",
      "metadata": {
