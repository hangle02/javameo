    {
      "id": "f67c43bb-ebb7-4c00-baab-30f8c6971c55",
      "cell_type": "code",
      "source": "BST myTree = new BST();\r\n        // Chọn 50 làm gốc (Root)\r\n        myTree.insert(50);\r\n        \r\n        // Chèn các nhánh bên trái (Nhỏ hơn 50)\r\n        myTree.insert(30);\r\n        myTree.insert(20);\r\n        myTree.insert(40);\r\n        \r\n        // Chèn các nhánh bên phải (Lớn hơn 50)\r\n        myTree.insert(70);\r\n        myTree.insert(60);\r\n        myTree.insert(80);\r\n\r\nIO.println(myTree.search(70));\r\nmyTree.delete(70);\r\nIO.println(myTree.search(70));\r\nIO.println(myTree.search(60));",
      "metadata": {
        "language": "java",
        "id": "f67c43bb-ebb7-4c00-baab-30f8c6971c55",
        "executionSummary": {
