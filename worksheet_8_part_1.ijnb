    {
      "id": "9171c159-2066-4851-bb1e-c5a19b01c019",
      "cell_type": "code",
      "source": "public class BST {\r\n    \r\n    BinaryTreeNode<Integer> root;\r\n\r\n    public BST() {\r\n        root = null;\r\n    }\r\n\r\n    // --- INSERTION ---\r\n    public void insert(Integer key) {\r\n        root = insert_(root, key);\r\n    }\r\n\r\n    private BinaryTreeNode<Integer> insert_(BinaryTreeNode<Integer> node, Integer key) {\r\n        // Base case: Found an empty spot, create the node!\r\n        if (node == null) {\r\n            return new BinaryTreeNode<>(key, null, null);\r\n        }\r\n\r\n        // If key is smaller, go LEFT and RE-ATTACH\r\n        if (key.compareTo(node.data) < 0) {\r\n            node.left = insert_(node.left, key);\r\n        } \r\n        // If key is larger, go RIGHT and RE-ATTACH\r\n        else if (key.compareTo(node.data) > 0) {\r\n            node.right = insert_(node.right, key);\r\n        } \r\n        // If equal, it's a duplicate\r\n        else {\r\n            System.out.println(\"Duplicate key: \" + key);\r\n        }\r\n\r\n        // Return the unchanged node pointer to keep the tree connected!\r\n        return node;\r\n    }\r\n\r\n    // --- DELETION ---\r\n    public void delete(Integer key) {\r\n        root = delete_(root, key);\r\n    }\r\n\r\n    private BinaryTreeNode<Integer> delete_(BinaryTreeNode<Integer> node, Integer key) {\r\n        // Base Case: If the tree is empty or we didn't find the key\r\n        if (node == null) {\r\n            return null;\r\n        }\r\n\r\n        // 1. Traverse down the tree to find the node\r\n        if (key.compareTo(node.data) < 0) {\r\n            node.left = delete_(node.left, key);\r\n        } else if (key.compareTo(node.data) > 0) {\r\n            node.right = delete_(node.right, key);\r\n        } \r\n        // 2. We found the node to delete!\r\n        else {\r\n            // Case 1 & 2: Node has only one child or no child\r\n            if (node.left == null) {\r\n                return node.right; // Replaces current node with its right child (or null)\r\n            } else if (node.right == null) {\r\n                return node.left;  // Replaces current node with its left child\r\n            }\r\n\r\n            // Case 3: Node has TWO children\r\n            // Step A: Find the smallest value in the right subtree\r\n            Integer minValue = findMin(node.right);\r\n            \r\n            // Step B: Replace the current node's data with that minimum value\r\n            node.data = minValue;\r\n            \r\n            // Step C: Recursively delete that minimum value from the right subtree\r\n            node.right = delete_(node.right, minValue);\r\n        }\r\n\r\n        return node;\r\n    }\r\n\r\n    // Helper method to find the smallest value in a subtree\r\n    private Integer findMin(BinaryTreeNode<Integer> node) {\r\n        Integer minVal = node.data;\r\n        while (node.left != null) {\r\n            minVal = node.left.data;\r\n            node = node.left;\r\n        }\r\n        return minVal;\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "id": "9171c159-2066-4851-bb1e-c5a19b01c019",
        "executionSummary": {
          "executionOrder": 8,
