    {
      "id": "67a09e76-54fb-4cba-9027-3dbf173fb3ce",
      "cell_type": "code",
      "source": "class BST{\r\n    BinaryTreeNode<Integer> root;\r\n\r\n    public BST() {\r\n        root = null;\r\n    }\r\n    public BinaryTreeNode<Integer> insert_(BinaryTreeNode<Integer> origin_root, Integer key){\r\n        if(origin_root == null){\r\n            return new BinaryTreeNode<>(key, null, null);\r\n        }\r\n        else{\r\n            if(origin_root.data.equals(key)){\r\n                IO.print(\"Duplicate key\");\r\n            }\r\n            if(origin_root.data.compareTo(key)>0){\r\n                origin_root.left= insert_(origin_root.left,key);\r\n            }\r\n            if(origin_root.data.compareTo(key)<0){\r\n                origin_root.right =  insert_(origin_root.right,key);\r\n            }\r\n        }\r\n        return origin_root;\r\n\r\n    }\r\n    public void insert(Integer key){\r\n        root = insert_(root, key);\r\n    }\r\n\r\n    public boolean search(Integer key){\r\n        return search_(root, key);\r\n        \r\n    }\r\n\r\n    public boolean search_(BinaryTreeNode<Integer> node, Integer key){\r\n        if(node == null){\r\n            return false;\r\n        }\r\n        else{\r\n            if(key.equals(node.data)){\r\n                return true;\r\n            }\r\n            if(key.compareTo(node.data)<0){\r\n                return search_(node.left, key);\r\n            }\r\n            else{\r\n                return search_(node.right, key);\r\n            }\r\n        }\r\n    }\r\n\r\n    public void delete(int key){\r\n        root = delete_(root, key);\r\n    }\r\n\r\n    public BinaryTreeNode<Integer> delete_(BinaryTreeNode<Integer> node, Integer key){\r\n        if(node==null){\r\n            return null;\r\n        }\r\n        else{\r\n            if(node.data.compareTo(key)>0){\r\n                node.left = delete_(node.left, key);\r\n            }\r\n            if(node.data.compareTo(key)<0){\r\n                node.right = delete_(node.right, key);\r\n            }\r\n            else{\r\n                // node has only one/0 child\r\n                if(node.left == null){\r\n                    return node.right;\r\n                }\r\n                if(node.right == null){\r\n                    return node.left;\r\n                }\r\n                //if node has 2 child\r\n                else{\r\n                    //find min of right-sub tree\r\n                    Integer minVal = node.data;\r\n                    while(node.left!=null){\r\n                        minVal = node.left.data;\r\n                        node = node.left;\r\n                    }\r\n                    node.data = minVal;\r\n                    node.right = delete_(node.right, minVal);\r\n                }\r\n            }\r\n        }\r\n        return node;\r\n\r\n    }\r\n}",
      "metadata": {
        "language": "java",
