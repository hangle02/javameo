    {
      "id": "e71050ce-cbd1-49aa-95f4-fd6e9e319001",
      "cell_type": "code",
      "source": "TreeNode arr_toBST(int[] nums){\r\n    if(nums.length==0){return null;}\r\n    return buildTree(nums, 0, nums.length-1);\r\n}\r\n\r\nTreeNode buildTree(int[] nums, int left, int right){\r\n    if(left>right){\r\n        return null;\r\n    }\r\n    else{\r\n        int mid = left +(right -left)/2;\r\n        TreeNode root = new TreeNode(nums[mid], null, null);\r\n        root.left = buildTree(nums, left, mid-1);\r\n        root.right = buildTree(nums, mid+1, right);\r\n        return root;\r\n    }\r\n}\r\n\r\nint[] nums = new int[]{2,3,4,5,6,7,8,9};\r\nTreeNode root = to_BST(nums);\r\nprint_inorder(root);",
