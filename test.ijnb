    {
      "id": "2e277c4b-c278-49bb-ba21-dfe5132421a0",
      "cell_type": "code",
      "source": "boolean check_zig_zag(TreeNode root) {\r\n    if (root == null) return true;\r\n    \r\n    // Gốc không có con cũng là một cây ZigZag hợp lệ\r\n    if (root.left == null && root.right == null) return true;\r\n    \r\n    // Nếu gốc có cả 2 con -> Không phải là một đường đi đơn -> Sai\r\n    if (root.left != null && root.right != null) return false;\r\n    \r\n    // Bắt đầu khởi tạo luồng đi\r\n    if (root.left != null) {\r\n        // Vừa rẽ trái xong, node tiếp theo KỲ VỌNG phải rẽ phải (expectLeft = false)\r\n        return zig_zag_helper(root.left, false); \r\n    } else {\r\n        // Vừa rẽ phải xong, node tiếp theo KỲ VỌNG phải rẽ trái (expectLeft = true)\r\n        return zig_zag_helper(root.right, true); \r\n    }\r\n}\r\n\r\nboolean zig_zag_helper(TreeNode node, boolean expectLeft) {\r\n    if (node == null) return true;\r\n    \r\n    // Nếu là node lá (đã đi đến cuối đường an toàn) -> Hợp lệ\r\n    if (node.left == null && node.right == null) return true;\r\n    \r\n    // Nếu node có cả 2 con -> Vi phạm quy tắc đường đi đơn -> Sai\r\n    if (node.left != null && node.right != null) return false;\r\n    \r\n    // Xử lý logic ngoằn ngoèo\r\n    if (expectLeft) {\r\n        if (node.left != null) {\r\n            // Đi đúng hướng Trái, chặng tiếp theo sẽ kỳ vọng hướng Phải\r\n            return zig_zag_helper(node.left, false); \r\n        } else {\r\n            return false; // Bắt buộc rẽ trái nhưng lại chỉ có nhánh phải\r\n        }\r\n    } else { // Kỳ vọng rẽ phải (expectLeft == false)\r\n        if (node.right != null) {\r\n            // Đi đúng hướng Phải, chặng tiếp theo sẽ kỳ vọng hướng Trái\r\n            return zig_zag_helper(node.right, true); \r\n        } else {\r\n            return false; // Bắt buộc rẽ phải nhưng lại chỉ có nhánh trái\r\n        }\r\n    }\r\n}",
