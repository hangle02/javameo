    {
      "id": "0ff22d20-c88a-418c-a935-2145fa5d12cd",
      "cell_type": "code",
      "source": "public void print_preorder(TreeNode root){\r\n    if(root == null){\r\n        return;\r\n    }\r\n    else{\r\n        IO.print(root.data + \" \");\r\n        print_preorder(root.left);\r\n        print_preorder(root.right);\r\n    }\r\n}\r\n\r\npublic void print_inorder(TreeNode root){\r\n    if(root == null){\r\n        return;\r\n    }\r\n    else{\r\n        print_inorder(root.left);\r\n       IO.print(root.data + \" \");\r\n        print_inorder(root.right);\r\n    }\r\n}\r\npublic void print_postorder(TreeNode root){\r\n    if(root == null){\r\n        return;\r\n    }\r\n    else{\r\n        print_postorder(root.left);\r\n        print_postorder(root.right);\r\n       IO.print(root.data + \" \");\r\n    }\r\n}\r\npublic void print_bfs(TreeNode root){\r\n    if(root==null){\r\n        return;\r\n    }\r\n    else{\r\n        Deque<TreeNode> queue = new ArrayDeque<TreeNode>();\r\n        queue.offer(root);\r\n        while(!queue.isEmpty()){\r\n            TreeNode tmp = queue.poll();\r\n           IO.print(tmp.data + \" \");\r\n            if(tmp.left!=null){queue.offer(tmp.left);}\r\n            if(tmp.right!=null){queue.offer(tmp.right);}\r\n        }\r\n    }\r\n\r\n}\r\nTreeNode n3 = new TreeNode(3, null, null);\r\n        TreeNode n4 = new TreeNode(4, n3, null);\r\n        TreeNode n1 = new TreeNode(1, null, null);\r\n        TreeNode n6 = new TreeNode(6, n1, n4);\r\n        TreeNode n9 = new TreeNode(9, null, null);\r\n        TreeNode n2 = new TreeNode(2, null, n9);\r\n        TreeNode n7 = new TreeNode(7, null, n2);\r\n        TreeNode n5 = new TreeNode(5, n6, n7);\r\n\r\nprint_bfs(n5);\r\n\r\n",
      "metadata": {
