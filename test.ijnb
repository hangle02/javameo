    {
      "id": "17eb9d37-0000-4340-8c60-da99d559bb7e",
      "cell_type": "code",
      "source": "boolean check_zig_zag(TreeNode root){\r\n    if(root==null){\r\n        return true;\r\n    }\r\n    return zig_zag_helper(root, true, true);\r\n\r\n}\r\n\r\nboolean zig_zag_helper(TreeNode root, boolean isLeft, boolean isRight){\r\n    if(root==null){\r\n        return true;\r\n    }\r\n    if(root.left==null && isRight==true && isLeft==false){\r\n        return false;\r\n    }\r\n    if(root.right==null && isLeft==true && isRight==false ){\r\n        return false;\r\n    }\r\n    return zig_zag_helper(root.left, true, false) || zig_zag_helper(root.right, false, true);\r\n}\r\n\r\nTreeNode root= new TreeNode(3,new TreeNode(2,null,null), new TreeNode(5,null,null));\r\nIO.println(check_zig_zag(root)); // false\r\nTreeNode root_1 = new TreeNode(1, new TreeNode(2, null, null), null);\r\nIO.println(check_zig_zag(root_1)); // true",
      "metadata": {
