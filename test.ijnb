    {
      "id": "49eee8a5-042a-49cd-b10d-9f20c45db13b",
      "cell_type": "code",
      "source": "// convert sorted array to bst\r\nTreeNode to_BST(int[] lst){\r\n    if(lst.length==0){return null;}\r\n    else{\r\n        return buildTree(lst, 0, lst.length-1);\r\n    }\r\n}\r\n// concept of binary search\r\nTreeNode buildTree(int[] nums, int left, int right){\r\n    if(left>right){\r\n        return null;\r\n    }\r\n    int mid = left + (right-left)/2;\r\n    TreeNode root = new TreeNode(nums[mid],null,null);\r\n    root.left = buildTree(nums, left, mid-1);\r\n    root.right = buildTree(nums, mid+1, right);\r\n    return root;\r\n}\r\n\r\nint[] nums = new int[]{2,3,4,5,6,7,8,9};\r\nTreeNode root = to_BST(nums);\r\nprint_inorder(root);\r\n",
      "metadata": {
        "language": "java",
        "id": "49eee8a5-042a-49cd-b10d-9f20c45db13b",
        "executionSummary": {
