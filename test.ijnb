    {
      "id": "504d4525-74b9-418d-992b-82b633cde474",
      "cell_type": "code",
      "source": "// right rotation\r\nclass AVLTreeNode{\r\n    public int data;\r\n    public int height;\r\n    public AVLTreeNode left;\r\n    public AVLTreeNode right;\r\n    public AVLTreeNode(int data_, AVLTreeNode left_, AVLTreeNode right_){\r\n        this.left = left_;\r\n        this.right = right_;\r\n        this.data = data_;\r\n        this.height = 1;\r\n    }\r\n}\r\nclass VisualTreeNode {\r\n    AVLTreeNode tree_node;\r\n    int depth;  // root depth = 0\r\n    int index;  // from 0 to 2^depth - 1\r\n    public VisualTreeNode(AVLTreeNode tree_node, int depth, int index) {\r\n        this.tree_node = tree_node;\r\n        this.depth = depth;\r\n        this.index = index;\r\n    }\r\n}\r\n\r\nclass AVL_Tree{\r\n    AVLTreeNode root;\r\n    public AVL_Tree(AVLTreeNode root_) {\r\n        root = root_;\r\n    }\r\n    public int height(AVLTreeNode node){\r\n        if(node==null){return 0;}\r\n        return node.height;\r\n    }\r\n    //Balance factor = H(right) - H(left)\r\n    int get_balance(AVLTreeNode node){\r\n        if(node==null){return 0;}\r\n        return height(node.right) - height(node.left);\r\n    }\r\n\r\n    //rotation\r\n    public AVLTreeNode right_rotation(AVLTreeNode node){\r\n        AVLTreeNode A = node;\r\n        AVLTreeNode B = node.left;\r\n        AVLTreeNode C = B.right;\r\n        B.right = A;\r\n        A.left = C; \r\n        //update height\r\n        A.height = 1 + Math.max(height(A.left), height(A.right));\r\n        B.height = 1 + Math.max(height(B.left), height(B.right));\r\n        return B;\r\n    }\r\n    public AVLTreeNode left_rotation(AVLTreeNode node){\r\n        AVLTreeNode A = node;\r\n        AVLTreeNode B = node.right;\r\n        AVLTreeNode C = B.left;\r\n        B.left = A;\r\n        A.right = C; \r\n        //update height\r\n        A.height = 1 + Math.max(height(A.left), height(A.right));\r\n        B.height = 1 + Math.max(height(B.left), height(B.right));\r\n        return B;\r\n    }\r\n    public void insert(int data){\r\n        root = insert_helper(root, data);\r\n    }\r\n    public AVLTreeNode insert_helper(AVLTreeNode node, int data){\r\n        if(node==null){\r\n            return new AVLTreeNode(data, null, null);\r\n        }\r\n        if(data<node.data){\r\n            node.left = insert_helper(node.left, data);\r\n        }\r\n        else if(data>node.data){\r\n            node.right = insert_helper(node.right, data);\r\n        }\r\n        else{\r\n            return node;\r\n        }\r\n        //update height\r\n        node.height = 1 + Math.max(height(node.left), height(node.right));\r\n        //balance factor\r\n        int balance = get_balance(node);\r\n        //4 cases\r\n        //left left case\r\n        if(balance<-1 && data<node.left.data){\r\n            return right_rotation(node);\r\n        }\r\n        //right right case\r\n        if(balance>1 && data>node.right.data){\r\n            return left_rotation(node);\r\n        }\r\n        //left right case\r\n        if(balance<-1 && data>node.left.data){\r\n            node.left = left_rotation(node.left);\r\n            return right_rotation(node);\r\n        }\r\n        //right left case\r\n        if(balance>1 && data<node.right.data){\r\n            node.right = right_rotation(node.right);\r\n            return left_rotation(node);\r\n        }\r\n        return node;\r\n    }\r\n\r\n    public void print() {\r\n        LinkedList<VisualTreeNode> queue = new LinkedList<VisualTreeNode>();\r\n        LinkedList<VisualTreeNode> result_queue = new LinkedList<VisualTreeNode>();\r\n        queue.add(new VisualTreeNode(root, 0, 0));\r\n        int max_depth = 0;\r\n        while (!queue.isEmpty()){\r\n            VisualTreeNode tmp = queue.remove();\r\n            result_queue.add(tmp);\r\n            if (max_depth < tmp.depth)\r\n                max_depth = tmp.depth;\r\n            if (tmp.tree_node.left != null)\r\n                queue.add(new VisualTreeNode(tmp.tree_node.left, tmp.depth + 1, 2*tmp.index));\r\n            if (tmp.tree_node.right != null)\r\n                queue.add(new VisualTreeNode(tmp.tree_node.right, tmp.depth + 1, 2*tmp.index + 1));\r\n        }\r\n        \r\n        int space_num = 4; // at the leaf node\r\n        int current_depth = 0;\r\n        String line = \"\", path = \"\";\r\n        int current_line_pos = 0, current_path_pos = 0;\r\n        while (!result_queue.isEmpty()) {\r\n            VisualTreeNode tmp = result_queue.remove();\r\n            if (tmp.depth > current_depth) {\r\n                current_depth++;\r\n                if (current_depth > 1)\r\n                    System.out.println(path);\r\n                System.out.println(line);\r\n                line = path = \"\";\r\n                current_line_pos = current_path_pos = 0;\r\n            }\r\n            // Update the line (i.e. tree node info)\r\n            int padding = (int) Math.round(((Math.pow(2, max_depth - tmp.depth) - 1)/2)*space_num);\r\n            int width = (int) Math.pow(2, max_depth - tmp.depth)*space_num;\r\n            int line_pos = padding + tmp.index*width;\r\n            for (int i = current_line_pos; i <= line_pos; i++)\r\n                line += \" \";\r\n            //line += Integer.toString(tmp.tree_node.key);\r\n            line += String.valueOf(tmp.tree_node.data);\r\n            current_line_pos = line_pos + 1;\r\n            // Update the path (i.e. \"/\" and \"\\\" to connect nodes)\r\n            int parent_index = (int)Math.round((tmp.index - 0.5)/2);\r\n            int parent_padding = padding + width/2;\r\n            int parent_width = 2*width;\r\n            int path_pos = (line_pos + parent_padding + parent_index*parent_width)/2;\r\n            for (int i = current_path_pos; i <= path_pos; i++)\r\n                path += \" \";\r\n            path += ((tmp.index % 2 == 0)? \"/\":\"\\\\\");\r\n            current_path_pos = path_pos + 1; \r\n            if (result_queue.isEmpty()) {\r\n                if (current_depth > 0)\r\n                    System.out.println(path);\r\n                System.out.println(line);\r\n            } \r\n        }\r\n    }\r\n\r\n\r\n}\r\n\r\nAVL_Tree my_tree = new AVL_Tree();\r\nint[] key_list = {15, 20, 24, 10, 13, 7, 30, 36, 25};\r\nfor (int key: key_list) {\r\n    my_tree.insert(key);\r\n    my_tree.print();\r\n}",
