    {
      "id": "0421eda8-2579-4b1a-a9cb-d9ce8ac233a9",
      "cell_type": "code",
      "source": "class Node{\r\n    public int data;\r\n    public Node(int data_){\r\n        this.data = data_;\r\n    }\r\n}\r\n\r\nNode a = new Node(1);\r\nNode b = new Node(2);\r\na = b;\r\nb = new Node(99);\r\nSystem.out.println(a.data);\r\n\r\nInteger val1 = Integer.valueOf(127);\r\nInteger val2 = Integer.valueOf(127);\r\nInteger val3 = new Integer(127);\r\nSystem.out.println((val1 == val2) + \" \" + (val1 == val3));\r\n\r\nvoid modify(int[] arr) {\r\n    arr[0] = 99;\r\n    arr = new int[]{1, 2, 3};\r\n}\r\n\r\n    int[] nums = {10, 20, 30};\r\n    modify(nums);\r\n    System.out.println(nums[0]);\r\n",
      "metadata": {
