    {
      "id": "9b4da6ed-f1bb-45d4-97cf-567e785c32f2",
      "cell_type": "code",
      "source": "//Given a binary tree, find the lowest common ancestor (LCA) of two given nodes in the tree.\r\n//The lowest common ancestor is defined between two nodes p and q as the lowest node in T that has both p and q as descendants (where we allow a node to be a descendant of itself).\r\nTreeNode find_LCA(TreeNode root, TreeNode p, TreeNode q){\r\n    if(root == null){\r\n        return null;\r\n    }\r\n    if(root == p || root ==q){\r\n        return root;\r\n    }\r\n\r\n    TreeNode left_LCA = find_LCA(root.left,p,q);\r\n    TreeNode right_LCA = find_LCA(root.right,p,q);\r\n    if(left_LCA!=null && right_LCA!=null){\r\n        return root;\r\n    }\r\n    return (left_LCA!=null)? left_LCA: right_LCA;\r\n}   \r\nTreeNode root= new TreeNode(3,new TreeNode(2,new TreeNode(1,null,null),new TreeNode(4,null,null)), new TreeNode(5,null,null));\r\nTreeNode p = root.left.right; // node 4\r\nTreeNode q = root.left.left; // node 1\r\nTreeNode LCA = find_LCA(root, p, q);\r\nIO.println(LCA.data); // 2\r\n",
      "metadata": {
        "language": "java",
        "id": "9b4da6ed-f1bb-45d4-97cf-567e785c32f2",
        "executionSummary": {
          "executionOrder": 18,
          "success": true
        }
      },
      "execution_count": 18,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "2\r\n"
          },
          "metadata": {},
          "execution_count": 18
        }
      ]
    },
    {
      "id": "b9373725-fa14-492e-a5fb-94e3d340de60",
      "cell_type": "code",
      "source": "//Given the root of a binary search tree, and an integer k, \r\n// return the kth smallest value (1-indexed) of all the values of the nodes in the tree.\r\nimport java.util.List;\r\nimport java.util.ArrayList;\r\nint kth_biggest(TreeNode root, int k){\r\n    if(root ==null){\r\n        return 0;\r\n    }\r\n    else{\r\n        List<Integer> datas = new ArrayList<>();\r\n        Deque<TreeNode> stack = new ArrayDeque<>();\r\n        TreeNode cur = root;\r\n        while(cur!=null || !stack.isEmpty()){\r\n            while(cur!=null){\r\n                stack.push(cur);\r\n                cur = cur.right;\r\n            }\r\n            cur = stack.pop();\r\n            datas.add(cur.data);\r\n            cur = cur.left;\r\n        }\r\n        IO.println(datas);\r\n        if(k <= datas.size()){return datas.get(k-1);}\r\n        return 0;\r\n    }\r\n}\r\nTreeNode root= new TreeNode(3,new TreeNode(1,null,null), new TreeNode(4,null,null));\r\nint k = 1;\r\nIO.println(kth_biggest(root, k));\r\n",
      "metadata": {
        "language": "java",
        "id": "b9373725-fa14-492e-a5fb-94e3d340de60",
        "executionSummary": {
          "executionOrder": 19,
          "success": true
        }
      },
      "execution_count": 19,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[4, 3, 1]\r\n4\r\n"
          },
          "metadata": {},
          "execution_count": 19
        }
      ]
    },
    {
      "id": "19d5c35b-851e-441c-8bcb-f2e1f147a0d1",
      "cell_type": "code",
      "source": "int kth_smallest(TreeNode root, int k){\r\n    if(root==null){return 0;}\r\n    else{\r\n        List<Integer> datas = new ArrayList<>();\r\n        Deque<TreeNode> stack = new ArrayDeque<>();\r\n        TreeNode cur = root;\r\n        while(cur!=null || !stack.isEmpty()){\r\n            while(cur!=null){\r\n                stack.push(cur);\r\n                cur=cur.left;\r\n            }\r\n            cur = stack.pop();\r\n            datas.add(cur.data);\r\n            cur = cur.right;\r\n        }\r\n        return datas.get(k-1);\r\n    }\r\n}\r\n\r\nTreeNode root= new TreeNode(3,new TreeNode(1,null,null), new TreeNode(4,null,null));\r\nint k = 3;\r\nIO.println(kth_smallest(root, k));\r\n",
