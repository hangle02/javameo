    {
      "id": "88512fca-e67f-4ecc-b56a-dfbeed9f22e9",
      "cell_type": "code",
      "source": "public TreeNode delete_one_child_node(TreeNode node){\r\n    if(node == null){\r\n        return node;\r\n    }\r\n    node.left = delete_one_child_node(node.left);\r\n    node.right = delete_one_child_node(node.right);\r\n\r\n    if(node.right==null && node.left!=null){\r\n        return node.left;\r\n    }\r\n    else if(node.right!=null && node.left==null){\r\n        return node.right;\r\n    }\r\n    return node;\r\n}",
      "metadata": {
        "language": "java",
        "id": "88512fca-e67f-4ecc-b56a-dfbeed9f22e9",
        "executionSummary": {
