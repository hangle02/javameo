    {
      "id": "fd8652d6-f617-4a84-b7da-f6b62eab3e63",
      "cell_type": "code",
      "source": "int get_max(TreeNode root){\r\n    if(root == null){\r\n        return 0;\r\n    }\r\n    if(root.left ==null && root.right == null){\r\n        return root.data;\r\n    }\r\n    if(root.left==null){\r\n        return Math.max(root.data, get_max(root.right));\r\n    }\r\n    if(root.right==null){\r\n        return Math.max(root.data, get_max(root.left));\r\n    }\r\n    return Math.max(root.data, Math.max(get_max(root.left), get_max(root.right)));\r\n}\r\n\r\nint get_min(TreeNode root){\r\n    if(root == null){\r\n        return 0;\r\n    }\r\n    if(root.left ==null && root.right == null){\r\n        return root.data;\r\n    }\r\n    if(root.left==null){\r\n        return Math.min(root.data, get_min(root.right));\r\n    }\r\n    if(root.right==null){\r\n        return Math.min(root.data, get_min(root.left));\r\n    }\r\n    return Math.min(root.data, Math.min(get_min(root.left), get_min(root.right)));\r\n}\r\n\r\nint get_height(TreeNode node){\r\n    if(node == null){\r\n        return 0;\r\n    }\r\n    return 1 + Math.max(get_height(node.left), get_height(node.right));\r\n}\r\n\r\nint balance_factor(TreeNode root){\r\n    if(root ==null){return 0;}\r\n    return (get_height(root.right)-get_height(root.left));\r\n}\r\n\r\nboolean is_BST(TreeNode node){\r\n    if(node==null){\r\n        return true;\r\n    }\r\n    if(node.left!=null && get_max(node.left)>=node.data){\r\n        return false;\r\n    }\r\n\r\n    if(node.right!=null && get_min(node.right)<=node.data){\r\n        return false;\r\n    }\r\n    return is_BST(node.left) && is_BST(node.right);\r\n}\r\n\r\nboolean is_AVL(TreeNode root){\r\n    if(root==null){\r\n        return true;\r\n    }\r\n    if((root.left==null || root.right==null) && (!is_BST(root) || Math.abs(balance_factor(root))>1)){\r\n        return false;\r\n    }\r\n    return is_AVL(root.left) && is_AVL(root.right);\r\n\r\n}\r\n\r\nTreeNode root= new TreeNode(3,new TreeNode(2,new TreeNode(1,null,null),null), new TreeNode(5,null,null));\r\nIO.println(balance_factor(root));\r\n\r\nIO.println(get_min(root));\r\nIO.println(get_max(root));\r\nIO.println(is_AVL(root));\r\n",
      "metadata": {
        "language": "java",
        "id": "fd8652d6-f617-4a84-b7da-f6b62eab3e63",
        "executionSummary": {
          "executionOrder": 15,
          "success": true
        }
      },
      "execution_count": 15,
