    {
      "id": "b1454bc1-4401-4efc-b1c9-858501248bcf",
      "cell_type": "code",
      "source": "\r\n    public static boolean check_balanced_parenthesis_str(String s){\r\n        int count = 0;\r\n        for (int i=0; i<s.length(); i++){\r\n            char c = s.charAt(i);\r\n            if(c=='('){\r\n                count++;\r\n            }\r\n            if(s.charAt(i)==')'){\r\n                count--;\r\n            }\r\n            if(count<0){\r\n                return false;\r\n            }\r\n        }\r\n        if(count ==0){return true;}\r\n        return false;\r\n\r\n   }\r\n   System.out.println(check_balanced_parenthesis_str(\")(())\")); // true \r\n\r\n\r\n",
      "metadata": {
        "language": "java",
