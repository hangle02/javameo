          "data": {
            "text/plain": "true\r\n"
          },
          "metadata": {},
          "execution_count": 24
        }
      ]
    },
    {
      "id": "f4c439a1-379b-423a-926c-1ca978849eb6",
      "cell_type": "code",
      "source": "boolean search_BST(TreeNode root, int k){\r\n    if(root==null){\r\n        return false;\r\n    }\r\n    else{\r\n        if(root.data==k){\r\n            return true;\r\n        }\r\n        if(root.data>k){\r\n            return search_BST(root.left,k);\r\n        }\r\n        else if(root.data<k){\r\n            return search_BST(root.right,k);\r\n        }\r\n    }\r\n    return false;\r\n}\r\n\r\nint[] nums = new int[]{2,3,4,5,6,7,8,9};\r\nTreeNode root = to_BST(nums);\r\nprint_inorder(root);\r\nIO.println();\r\nIO.println(search_BST(root, 5));",
      "metadata": {
