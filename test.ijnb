    {
      "id": "fe1092b5-3f96-4b9e-8548-137bc2dc83a5",
      "cell_type": "code",
      "source": "int longestZigZag(TreeNode root) {\r\n        if(root == null){\r\n            return 0;\r\n        }\r\n        else{\r\n            int max_length = 0;\r\n            Deque<TreeNode> stack = new ArrayDeque<>();\r\n            Deque<Integer> length_stack = new ArrayDeque<>();\r\n            stack.push(root);\r\n            length_stack.push(0);\r\n            while(!stack.isEmpty()){\r\n                TreeNode tmp = stack.pop();\r\n                int length = length_stack.pop();\r\n                max_length = Math.max(max_length, length);\r\n                if(tmp.left!=null){\r\n                    stack.push(tmp.left);\r\n                    length_stack.push(length+1);\r\n                }\r\n                if(tmp.right!=null){\r\n                    stack.push(tmp.right);\r\n                    length_stack.push(length+1);\r\n                }\r\n            }\r\n            return max_length;\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "id": "fe1092b5-3f96-4b9e-8548-137bc2dc83a5",
        "executionSummary": {
          "executionOrder": 21,
