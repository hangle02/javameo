      "id": "afda391d-8378-48c4-a639-0407c255fe5e",
      "cell_type": "code",
      "source": "int max_road = 0;\r\n\r\nint longestZigZag(TreeNode root){\r\n    if(root==null){return 0;}\r\n    dfs(root.left, true, 1);\r\n    dfs(root.right,false,1);\r\n    return max_road;\r\n}\r\n\r\nvoid dfs(TreeNode node, boolean isLeft, int curlen){\r\n    if(node==null){return;}\r\n    max_road = Math.max(max_road, curlen);\r\n    if(isLeft){\r\n        dfs(node.right, false, curlen+1);\r\n        dfs(node.left, true, 1);\r\n    }\r\n    else{\r\n        dfs(node.left, true, curlen+1);\r\n        dfs(node.right,false,1);\r\n    }\r\n}",
