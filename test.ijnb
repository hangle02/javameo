    {
      "id": "a23a8682-3c31-4b83-9b49-99f7e97b2bb2",
      "cell_type": "code",
      "source": "void invert_tree(TreeNode root){\r\n    if(root == null){return;}\r\n    else{   \r\n            TreeNode cur = root;\r\n            TreeNode tmp = cur.left;\r\n            cur.left = cur.right;\r\n            cur.right = tmp;\r\n            invert_tree(cur.left);\r\n            invert_tree(cur.right);\r\n            \r\n        }\r\n    }\r\n\r\nTreeNode root= new TreeNode(3,new TreeNode(2,new TreeNode(1,null,null),null), new TreeNode(5,null,null));\r\nprint_bfs(root);\r\nIO.println();\r\ninvert_tree(root);\r\nprint_bfs(root);",
