    {
      "id": "b61ce532-47fc-4218-92fd-d58b1ddb0d36",
      "cell_type": "code",
      "source": "boolean same_tree(TreeNode root1, TreeNode root2){\r\n    if(root1==null && root2==null){\r\n        return true;\r\n    }\r\n    if((root1!=null && root2==null)||(root1==null && root2!=null)){\r\n        return false;\r\n    }\r\n    else{\r\n        if(root1.data!=root2.data){return false;}\r\n        return (same_tree(root1.left,root2.left) && same_tree(root1.right,root2.right));\r\n    }\r\n}\r\n\r\nTreeNode root1 = new TreeNode(1, new TreeNode(2, null, null), new TreeNode(3, null, null));\r\nTreeNode root2 = new TreeNode(1, new TreeNode(2, null, null), new TreeNode(3, null, null));\r\nIO.println(same_tree(root1, root2)); // true",
      "metadata": {
        "language": "java",
        "id": "b61ce532-47fc-4218-92fd-d58b1ddb0d36",
        "executionSummary": {
          "executionOrder": 24,
          "success": true
        }
      },
      "execution_count": 24,
      "outputs": [
