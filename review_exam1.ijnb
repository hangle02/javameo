    {
      "id": "b59d0915-3e12-425e-9fd0-4ffe42befe8f",
      "cell_type": "code",
      "source": "boolean check_balanced_parenthesis_str(String str){\r\n    int count=0;\r\n    for(int i=0; i<str.length; i++){\r\n        char c= str.charAt(i);\r\n        if(c=='{'){\r\n            count++;\r\n        }\r\n        if(c=='}'){\r\n            count--;\r\n        }\r\n        if(count<0){\r\n            return false;\r\n        }\r\n    }\r\n    if(count==0){\r\n        return true;\r\n    }\r\n    return false;\r\n}\r\n",
