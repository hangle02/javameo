    {
      "id": "df491128-30cc-4140-bcfe-71a6f91348ac",
      "cell_type": "code",
      "source": "int binary_search(int[] arr, int key){\r\n    if(arr==null){return -1;}\r\n    int left =0;\r\n    int right = arr.length-1;\r\n    while(left<=right){\r\n        int mid = left + (right-left)/2;\r\n        if(key<arr[mid]){\r\n            right = mid-1;\r\n        }\r\n        if(key> arr[mid]){\r\n            left = mid+1;\r\n        }\r\n        if(key == arr[mid]){\r\n            return mid;\r\n        }\r\n    }\r\n    return -1;\r\n}\r\nint[] arr_1 ={1,2,3,5,8};\r\nIO.println(binary_search(arr_1, 3));",
      "metadata": {
        "language": "java",
        "id": "df491128-30cc-4140-bcfe-71a6f91348ac",
        "executionSummary": {
          "executionOrder": 16,
          "success": true
        }
      },
