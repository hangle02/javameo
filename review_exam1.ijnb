    {
      "id": "f97f703f-c99a-47a3-96d1-2df7cd235870",
      "cell_type": "code",
      "source": "void bubble_sort(int[] arr){\r\n    //check arr\r\n    if(arr==null || arr.length<2){\r\n        return;\r\n    }\r\n    for(int k=0; k<arr.length-1; k++){\r\n        boolean swap = false;\r\n        for(int i=0; i<arr.length-1-k; i++){\r\n            if(arr[i]>arr[i+1]){\r\n                int tmp = arr[i];\r\n                arr[i] = arr[i+1];\r\n                arr[i+1] = tmp;\r\n                swap = true;\r\n            }\r\n        }\r\n        if (!swap){break;}\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 2,
          "success": true
        }
      },
      "execution_count": 2,
      "outputs": [
