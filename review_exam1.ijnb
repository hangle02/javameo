    {
      "id": "b38a0909-e9f3-4ee6-afe6-50e689b1bdb6",
      "cell_type": "code",
      "source": "void backtracking(int[] result, boolean[] used, int pos, int n){\r\n    //base case\r\n    if(pos==n){\r\n        IO.println(result);\r\n        return;\r\n    }\r\n    for(int i =1; i<=n; i++){ \r\n        if(!used[i]){\r\n            result[pos] =i;\r\n            used[i] = true;\r\n\r\n            backtracking(result, used, pos+1,n);\r\n            used[i] = false;\r\n        }\r\n    }\r\n}",
      "metadata": {
        "language": "java"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "id": "2ff47ffa-277c-49cc-a40a-e7ce6bdf1c7b",
      "cell_type": "code",
      "source": "void print_permutations(int n, int pos, boolean[] used, int[] result){\r\n     //base case: \r\n     if(pos == n){\r\n        IO.println(Arrays.toString(result));\r\n        return;\r\n     }\r\n    for(int i =0; i<=n; i++){\r\n        if(used[i]==false){\r\n            result[pos] =i;\r\n            used[i] = true;\r\n            print_permutations(n, pos+1, used, result);\r\n            used[i] = false;\r\n        }\r\n\r\n    }\r\n}\r\n\r\nvoid print_all_permutation(int n){\r\n    int[] result = new int[n];\r\n    boolean[] used = new boolean[n+1];\r\n    print_permutations(n, 0, used, result);\r\n\r\n}",
      "metadata": {
        "language": "java",
        "id": "2ff47ffa-277c-49cc-a40a-e7ce6bdf1c7b",
        "executionSummary": {
          "executionOrder": 17,
