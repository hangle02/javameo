    {
      "id": "705eb44d-867d-4089-86e1-1a1a1e68e205",
      "cell_type": "code",
      "source": "\r\ninterface Linklist<T>{\r\n    //add value\r\n    public void add(T value);\r\n\r\n    //add(index, value)\r\n    public boolean addbyIndex(int index, T value);\r\n\r\n    // public boolean contains(T value);\r\n\r\n    // public int indexOf(T value);\r\n\r\n    // public boolean isEmpty();\r\n\r\n    // public boolean remove(T value);\r\n\r\n    // public void clear();\r\n\r\n    // public T getIndex(int index);\r\n\r\n    // public boolean removeI(int index);\r\n\r\n    // public int size();\r\n\r\n    // public void set(int index, T value);\r\n\r\n    // public void reverse();\r\n\r\n    // public void delete_duplicate();\r\n\r\n    // public void printlinklist();\r\n\r\n    // public void linklistSort(Comparator<T> comparator);\r\n\r\n    // public boolean checkCircular();\r\n\r\n    // public T getMid();\r\n}\r\n\r\nclass Node<T>{\r\n    T data;\r\n    Node<T> next;\r\n    Node(T data_, Node<T> next_){\r\n        data = data_;\r\n        next = next_;\r\n    }\r\n}\r\n\r\npublic class linkedlist<T> implements Linklist<T> {\r\n    Node<T> head;\r\n    int length;\r\n\r\n    public linkedlist(){\r\n        head = null;\r\n        length = 0;\r\n    }\r\n\r\n        //add value\r\n    public void add(T value){\r\n        Node<T> newNode = new Node(value, null);\r\n        length++;\r\n        if(head == null){\r\n            head = newNode;\r\n        }\r\n        else{\r\n        Node<T> curNode = head;\r\n\r\n        while(curNode.next!=null){\r\n            curNode = curNode.next;\r\n        }\r\n        curNode.next = newNode;\r\n        }\r\n    }\r\n\r\n    //add(index, value)\r\n    public boolean  addbyIndex(int index, T value){\r\n        Node<T> newNode = new Node(value, null);\r\n        if(index >= length){\r\n            return false;\r\n        }\r\n        Node<T> curNode = head;\r\n        int curIndex = 0;\r\n        while(curNode.next!=null){\r\n            if(curIndex == index-1){\r\n                newNode.next = curNode.next;\r\n                curNode.next = newNode;\r\n                return true;\r\n            }\r\n            curNode = curNode.next;\r\n            curIndex++;\r\n        }\r\n        return false;\r\n    }\r\n\r\n    // public boolean contains(T value){\r\n    //     return false;\r\n    // }\r\n\r\n    // public int indexOf(T value){\r\n    //     return -1;\r\n    // }\r\n\r\n    // public boolean isEmpty(){\r\n    //     return false;\r\n    // }\r\n\r\n    // public boolean remove(T value){\r\n    //     return false;\r\n    // }\r\n\r\n    // public void clear(){\r\n        \r\n    // }\r\n\r\n    // public T getIndex(int index){\r\n    //     return head.data;\r\n    // }\r\n\r\n    // public boolean removeI(int index){\r\n    //     return false;\r\n    // }\r\n\r\n    // public int size(){\r\n    //     return length;\r\n    // }\r\n\r\n    // public void set(int index, T value){}\r\n\r\n    // public void reverse(){}\r\n\r\n    // public void delete_duplicate(){}\r\n\r\n    // public void printlinklist(){}\r\n\r\n    // public void linklistSort(Comparator<T> comparator){}\r\n\r\n    // public boolean checkCircular(){\r\n    //     return true;\r\n    // }\r\n\r\n    // public T getMid(){\r\n    //     return head.data;\r\n    // }\r\n    public static void main(String[] args) {\r\n        linkedlist<Integer> list_1 = new linkedlist<>();\r\n        list_1.add(1);\r\n        list_1.add(2);\r\n        list_1.add(3);\r\n\r\n        list_1.add(10);\r\n        list_1.add(6);\r\n        list_1.add(1);\r\n        list_1.add(1);\r\n        list_1.add(1);\r\n\r\n        \r\n        \r\n    }\r\n}\r\n",
