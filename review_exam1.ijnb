    {
      "id": "6d40912c-c9a2-444b-954b-768ca3a177b2",
      "cell_type": "code",
      "source": "void insertion_sort(int[] arr){\r\n    if(arr==null||arr.length<2){\r\n        return;\r\n    }\r\n    for(int i=1; i<arr.length; i++){\r\n        int key = arr[i];\r\n        int j = i-1;\r\n        while(j>=0 && arr[j]>key){\r\n            arr[j+1] = arr[j];\r\n            j = j-1;\r\n        }\r\n        arr[j+1] = key;\r\n    }\r\n}",
      "metadata": {
        "language": "java"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "id": "5d8fb4ca-0a3d-4e5c-830c-2457c1768c62",
      "cell_type": "code",
      "source": "int linear_search(int[] arr, int key){\r\n    if(arr==null){return -1;}\r\n    for(int i=0; i<arr.length; i++){\r\n        if(key==arr[i]){return i;}\r\n    }\r\n    return -1;\r\n}\r\n\r\nint[] arr_1 ={1,2,3,5,8};\r\nIO.println(linear_search(arr_1, 3));",
      "metadata": {
