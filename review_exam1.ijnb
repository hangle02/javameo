    {
      "id": "fe0e8232-8e5b-4ba4-8f84-abae072db268",
      "cell_type": "code",
      "source": "void selection_sorting(int[] arr){\r\n    if(arr==null||arr.length<2){\r\n        return;\r\n    }\r\n    for(int i=0; i< arr.length-1; i++){\r\n        int minIndex = i;\r\n        for(int j=i+1; j<arr.length; j++ ){\r\n            if(arr[minIndex]> arr[j]){\r\n                minIndex = j;\r\n            }\r\n        }\r\n        int tmp = arr[i];\r\n        arr[i] = arr[minIndex];\r\n        arr[minIndex] = arr[i];\r\n\r\n    }\r\n}",
      "metadata": {
        "language": "java",
        "executionSummary": {
          "executionOrder": 8,
          "success": true
        }
