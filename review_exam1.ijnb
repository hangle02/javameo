    {
      "id": "d831cca4-fe1c-4c99-9e3a-56f317b1ffdc",
      "cell_type": "code",
      "source": "import java.util.Queue;\r\nimport java.util.LinkedList;\r\n\r\nString[] split_sentence(String s){\r\n    String[] str = s.split(\" \");\r\n    Queue<String> word = new LinkedList<>();\r\n    for(String w: str){\r\n        if(!word.contains(w)){\r\n            word.offer(w);\r\n        }\r\n    }\r\n    String[] r = new String[word.size()];\r\n    for(int i=0; i<r.length; i++){\r\n        r[i] = word.poll();\r\n    }\r\n    return r;\r\n}",
      "metadata": {
        "language": "java",
        "id": "d831cca4-fe1c-4c99-9e3a-56f317b1ffdc",
