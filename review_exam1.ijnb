    {
      "id": "19e2743c-624a-4d57-a22b-6a7f5752815b",
      "cell_type": "code",
      "source": "void print_subsets(int n, int pos, int[] current_subset){\r\n    if(pos>n){\r\n        IO.println(Arrays.toString(current_subset));\r\n        return;\r\n    }\r\n\r\n    int[] new_subset = Arrays.copyOf(current_subset, current_subset.length+1);\r\n    new_subset[new_subset.length-1] = pos;\r\n    print_subsets(n, pos+1, new_subset);\r\n    print_subsets(n, pos+1, current_subset);\r\n}\r\n\r\nvoid print_all_subsets(int n){\r\n    int[] arr = new int[0];\r\n    print_subsets(n, 1, arr);\r\n}\r\n\r\nprint_all_subsets(2);",
